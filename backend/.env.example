# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# GROQ_API_KEY: Optional API key for Groq engine.
GROQ_API_KEY=

# MISTRAL_API_KEY: Optional API key for Mistral engine.
MISTRAL_API_KEY=

# Clerk Authentication Keys
VITE_CLERK_PUBLISHABLE_KEY=your-clerk-publishable-key-here

CLERK_SECRET_KEY=your-clerk-secret-key-here

# JWT Secret for Simple Email/Password Auth
JWT_SECRET=

# MongoDB Persistent Cloud Database
MONGODB_URI=

# Cloudinary Media Storage for Images and Docx
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Resend Transactional Email API Key
RESEND_API_KEY=

